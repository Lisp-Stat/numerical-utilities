#!/usr/bin/env bash
# RALPH loop for Common Lisp projects (SBCL + ASDF + clunit2)
# Based on https://github.com/snarktank/ralph
#
# Usage: ./ralph.sh [--tool claude|amp] [max_iterations]

set -euo pipefail

TOOL="${1:-claude}"
MAX_ITERATIONS="${2:-30}"
PRD_FILE="prd.json"
PROGRESS_FILE="progress.txt"

# BEGIN PROJECT-SPECIFIC
PROJECT_DIR="/usr/local/symbolics/src/num-utils"
TEST_CMD="cd ${PROJECT_DIR} && sbcl --non-interactive \
  --eval '(push #p\"${PROJECT_DIR}/\" asdf:*central-registry*)' \
  --eval '(ql:quickload :num-utils :silent t)' \
  --eval '(ql:quickload :clunit2 :silent t)' \
  --eval '(asdf:test-system \"num-utils\")'"
# END PROJECT-SPECIFIC

if [[ "${TOOL}" == "--tool" ]]; then
  TOOL="${2:-claude}"
  MAX_ITERATIONS="${3:-30}"
fi

echo "=== RALPH Loop ==="
echo "Tool: ${TOOL}"
echo "Max iterations: ${MAX_ITERATIONS}"
echo "PRD: ${PRD_FILE}"
echo ""

for ((i=1; i<=MAX_ITERATIONS; i++)); do
  echo "--- Iteration ${i}/${MAX_ITERATIONS} ---"

  # Check if all stories pass
  if command -v jq &>/dev/null && [[ -f "${PRD_FILE}" ]]; then
    REMAINING=$(jq '[.userStories[] | select(.passes == false)] | length' "${PRD_FILE}")
    if [[ "${REMAINING}" -eq 0 ]]; then
      echo "<promise>COMPLETE</promise>"
      echo "All user stories pass. RALPH loop complete."
      exit 0
    fi
    echo "Remaining stories: ${REMAINING}"
  fi

  # Run the AI tool
  if [[ "${TOOL}" == "claude" ]]; then
    claude --print "Read prd.json and progress.txt. Pick the highest-priority story where passes is false. Implement it, run tests, commit if green, update prd.json and progress.txt."
  elif [[ "${TOOL}" == "amp" ]]; then
    amp --prompt-file .github/prompts/continue-work.prompt.md
  else
    echo "Unknown tool: ${TOOL}"
    exit 1
  fi

  echo ""
done

echo "Max iterations (${MAX_ITERATIONS}) reached."
echo "Check prd.json for remaining stories."
